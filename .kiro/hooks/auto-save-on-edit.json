{
  "version": "v1",
  "hooks": [
    {
      "name": "Auto Save on File Edit",
      "trigger": "PostToolUse",
      "description": "Confirms files are saved after every edit operation",
      "matcher": "str_replace|fs_write|fs_append",
      "action": {
        "type": "command",
        "command": "echo Files saved automatically"
      }
    }
  ]
}